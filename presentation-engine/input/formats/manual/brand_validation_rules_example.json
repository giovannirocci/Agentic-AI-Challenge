{
  "rules_version": "brand_validation_rules_v1",
  "brand_name": "Example Brand",
  "source_profile_name": "example_profile",
  "hard_rules": {
    "allowed_colors": ["#24135F", "#D0006F"],
    "allowed_fonts": ["Arial", "Arial Unicode MS"],
    "allowed_slide_types": [
  "title",
  "section",
  "bullet",
  "two_column",
  "image",
  "bullet_summary",
  "comparison",
  "kpi_dashboard",
  "closing"
],
    "max_bullets_per_slide": 5,
    "max_title_words": 10,
    "require_footer": true,
    "require_logo": false,
    "logo_rules": {
      "allow_recolor": false,
      "allow_rotation": false,
      "allow_distortion": false,
      "allow_effects": false,
      "respect_protection_area": true,
      "allowed_backgrounds": ["#24135F", "#D0006F", "white"]
    }
  },
  "soft_rules": {
    "preferred_colors": {
      "general": "#24135F",
      "hr": "#D0006F",
      "finance": ""
    },
    "warnings_only": []
  },
  "validation_behavior": {
    "hard_rule_violation": "fail",
    "soft_rule_violation": "warn",
    "missing_optional_information": "warn",
    "missing_required_information": "fail"
  }
}