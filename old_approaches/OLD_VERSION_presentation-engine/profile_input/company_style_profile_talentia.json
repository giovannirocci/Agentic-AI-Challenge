{
  "profile_version": "company_style_profile_v1",
  "profile_name": "talentia_brand_profile",
  "description": "Talentia PowerPoint brand and formatting profile derived manually from the Talentia graphical charter for testing renderer compliance.",

  "branding": {
    "logo_required": true,
    "logo_asset_id": "company_logo",
    "logo_position": "top_right",
    "logo_max_width": 1.4,
    "logo_max_height": 0.5,
    "approved_logo_variants": ["full_color", "white", "responsive", "icon"],
    "white_logo_allowed_backgrounds": ["primary", "pink"],
    "forbidden_logo_treatments": [
      "recolor",
      "rotate",
      "shadow",
      "outline",
      "distort"
    ],
    "minimum_logo_width_mm": 33,
    "minimum_logo_width_preferred_mm": 45,
    "responsive_logo_allowed_below_px": 57,
    "icon_logo_allowed_below_px": 40
  },

  "colors": {
    "primary": "#24135F",
    "pink": "#D0006F",
    "grey": "#B1B3B3",
    "violet": "#422990",
    "turquoise": "#2DCCD3",
    "background": "#FFFFFF",
    "surface": "#F7F7FA",
    "text": "#1D1D1D",
    "muted_text": "#666666",
    "success": "#2E8B57",
    "warning": "#D97706",
    "danger": "#C0392B"
  },

  "color_usage": {
    "general_documents": ["primary", "pink", "grey", "violet"],
    "finance_documents": ["primary", "pink", "grey", "violet", "turquoise"],
    "hr_documents": ["primary", "pink", "grey", "violet"],
    "default_secondary_color": "violet",
    "finance_accent_color": "turquoise",
    "hr_accent_color": "pink"
  },

  "typography": {
    "brand_identity_font": "Campton",
    "office_title_font": "Arial",
    "office_body_font": "Arial",
    "office_caption_font": "Arial",
    "title_font": "Arial",
    "body_font": "Arial",
    "caption_font": "Arial",
    "title_size_default": 24,
    "title_size_min": 22,
    "title_size_max": 30,
    "subtitle_size_default": 16,
    "subtitle_size_min": 12,
    "subtitle_size_max": 20,
    "body_size_default": 14,
    "body_size_min": 12,
    "body_size_max": 20,
    "caption_size_default": 10,
    "caption_size_min": 8,
    "caption_size_max": 12
  },

  "spacing": {
    "page_margin_x": 0.8,
    "page_margin_y": 0.6,
    "block_gap": 0.3,
    "section_gap": 0.5,
    "safe_zone_top": 0.4,
    "safe_zone_bottom": 0.4,
    "logo_protection_area_rule": "1x_l_from_talentia"
  },

  "shape_style": {
    "corner_style": "rounded",
    "shadow_style": "none",
    "border_style": "light",
    "default_surface_style": "plain"
  },

  "footer": {
    "footer_required": true,
    "footer_text": "Confidential",
    "slide_numbers_required": true,
    "date_required": false
  },

  "density_rules": {
    "max_bullets_per_slide": 5,
    "max_words_per_bullet": 12,
    "max_total_words_per_slide": 45,
    "prefer_low_density_for_live_talk": true
  },

  "title_rules": {
    "title_required_on_all_slides": true,
    "max_title_words": 10,
    "preferred_title_alignment": "left",
    "subtitle_allowed": true
  },

  "allowed_slide_types": [
    "title",
    "section_divider",
    "agenda",
    "bullet_summary",
    "two_column",
    "comparison",
    "process_flow",
    "timeline",
    "kpi_dashboard",
    "image_focus",
    "table",
    "closing"
  ],

  "preferred_variants": {
    "title": ["hero"],
    "bullet_summary": ["standard", "highlighted"],
    "comparison": ["split_cards", "highlight_right"],
    "process_flow": ["horizontal_cards"],
    "kpi_dashboard": ["cards"],
    "closing": ["cta"]
  },

  "layout_rules": {
    "accent_bar_allowed": true,
    "accent_bar_default_position": "top",
    "background_styles_allowed": ["solid"],
    "surface_styles_allowed": ["plain", "card", "tinted"],
    "image_crop_modes_allowed": ["contain", "cover"],
    "default_reading_order": "left_to_right",
    "preferred_primary_color_usage": "primary",
    "preferred_accent_color_usage": "violet"
  },

  "validation_rules": {
    "reject_unsupported_slide_types": true,
    "reject_too_many_bullets": true,
    "reject_oversized_titles": true,
    "reject_missing_footer_when_required": true,
    "warn_on_dense_slides": true,
    "warn_on_missing_logo_when_logo_required": true,
    "reject_forbidden_logo_treatments": true,
    "reject_unapproved_colors": true,
    "warn_on_non_office_fonts": true
  }
}